#    General Axioms
#################################################################

###  https://cyberterrain.org/ns/stones#aliases
stones:aliases rdfs:domain stonework:ProductFamily .

###  https://cyberterrain.org/ns/stones#authors
stones:authors rdfs:domain stonework:ProductFamily .

###  https://cyberterrain.org/ns/stones#cpe
stones:cpe rdfs:domain stonework:Product .

###  https://cyberterrain.org/ns/stones#description
stones:description rdfs:domain stonework:ProductFamily .

###  https://cyberterrain.org/ns/stones#Identity
stones:Identity rdfs:subClassOf stonework:Agent .

###  https://cyberterrain.org/ns/stones#languages
stones:languages rdfs:domain stonework:ProductFamily .

###  https://cyberterrain.org/ns/stones#name
stones:name rdfs:domain stonework:ProductFamily .

###  https://cyberterrain.org/ns/stonework#releaseDate
stonework:releaseDate rdfs:domain stonework:Product .

###  https://cyberterrain.org/ns/stones#SoftwareObject
stones:SoftwareObject rdfs:subClassOf stonework:Product .

###  https://cyberterrain.org/ns/stones#swid
stones:swid rdfs:domain stonework:Product .

###  https://cyberterrain.org/ns/stones#ThreatActor
stones:ThreatActor rdfs:subClassOf stonework:Agent .

###  https://cyberterrain.org/ns/stones#version
stones:version rdfs:domain stonework:Product .
